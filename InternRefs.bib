	pages = {865--918},
	file = {BoustanEtAl_AutomatedHistLinking_2019.pdf:/Users/danteyasui/Zotero/storage/I5GVSFET/BoustanEtAl_AutomatedHistLinking_2019.pdf:application/pdf;Full Text:/Users/danteyasui/Zotero/storage/EDKW93WF/Abramitzky et al. - 2021 - Automated Linking of Historical Data.pdf:application/pdf},
