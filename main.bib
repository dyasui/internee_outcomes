  number = {3},
  pages = {238--269},
  issn = {1945-7782},
  doi = {10.1257/app.20210008},
  url = {https://www.aeaweb.org/articles?id=10.1257/app.20210008},
  urldate = {2024-10-10},
  abstract = {Whether immigrants advance in labor markets during their life- times relative to natives is a fundamental question in the economics of immigration. We examine linked census records for five cohorts spanning 1850--1940, when immigration to the United States was at its peak. We find a U-shaped pattern of assimilation: immigrants were "catching up" to natives in the early and later cohorts, but not in between. This change was not due to shifts in immigrants' source countries. Instead, it was rooted in men's early-career occupations, which we associate with structural change, strengthening complementarities, and large immigration waves in the 1840s and 1900s.},
  langid = {english},
  keywords = {19th century,20th century,Age of Migration,assimilation,census data,complimentarity,convergence,immigration,linked data,occupational choice,structural change,USA,year of arrival},
  file = {zotero://open-pdf/library/items/26MEZTR6?Collins and Zimran - 2023 - Working Their Way Up US Immigrants' Changing Labor Market Assimilation in the Age of Mass Migration.pdf}
}

