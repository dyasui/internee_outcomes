  year = {2024},
  month = jul,
  number = {4915911},
  eprint = {4915911},
  publisher = {Social Science Research Network},
  address = {Rochester, NY},
  url = {https://papers.ssrn.com/abstract=4915911},
  urldate = {2025-04-12},
  abstract = {This research note examines the effects of World War II military service on postwar outcomes for immigrants in the US. I take advantage of linked full-count US Census data, a triple-differences specification, and control for differential trends in counties with high volunteering rates to obtain causal estimates of the veteran effect for immigrants. I find that immigrant veterans were more likely to become naturalized citizens, become married, and were more likely to marry a spouse born in the US. In contrast, I do not find any consistent evidence that immigrant veterans were differently affected than their native-born counterparts for labor market or educational outcomes. Taken together, I find that serving in the US military during World War II hastened immigrant assimilation.},
  archiveprefix = {Social Science Research Network},
  langid = {english},
  keywords = {Jeff Chan,Proving their Loyalty: A Research Note on the Effects of Serving in World War II on Immigrant Outcomes,SSRN},
  file = {zotero://open-pdf/library/items/36KEDI24?Chan - 2024 - Proving their Loyalty A Research Note on the Effects of Serving in World War II on Immigrant Outcom.pdf}
}

