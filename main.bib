  doi = {10.1086/683186},
  url = {https://www.jstor.org/stable/10.1086/683186},
  urldate = {2024-10-05},
  abstract = {This paper considers the impact of skill-based immigration restrictions, using the Chinese Exclusion Act as a natural experiment. I find that restrictions reduced the average occupational standing of Chinese immigrants, suggesting substitution between observed and unobserved skills. Conversely, children of restricted immigrants have greater human capital than those of unrestricted immigrants, despite restricted immigrants themselves having lower skill. This suggests particularly strong intergenerational transmission of skill among Chinese immigrants of the exclusion era. More generally, the findings indicate that the effects of skill-based restrictions are not always straightforward and may be heterogeneous across groups.},
  file = {zotero://open-pdf/library/items/PHJ4C8PN?Chen - 2015 - The Impact of Skill-Based Immigration Restrictions The Chinese Exclusion Act of 1882.pdf}
}

@article{chenInstitutionalDiscriminationAssimilation2024,
  title = {Institutional Discrimination and Assimilation: {{Evidence}} from the {{Chinese Exclusion Act}} of 1882},
  shorttitle = {Institutional Discrimination and Assimilation},
  author = {Chen, Shuo and Xie, Bin},
  year = {2024},
  month = oct,
  journal = {Explorations in Economic History},
  volume = {94},
  pages = {101615},
  issn = {0014-4983},
  doi = {10.1016/j.eeh.2024.101615},
  url = {https://www.sciencedirect.com/science/article/pii/S001449832400041X},
  urldate = {2025-05-22},
  abstract = {The Chinese Exclusion Act of 1882 marked a pivotal moment in U.S. immigration policy, effectively prohibiting Chinese immigration while institutionalizing discrimination against Asians within American society. This study investigates the repercussions of such institutional discrimination on the assimilation process of Asian immigrants, leveraging the timing of the enactment of the Act and the regional variation in the intensity of discrimination. Using a difference-in-differences approach, we find that discrimination posed significant obstacles to the labor market integration of Asian immigrants during the Exclusion Era (1882--1943), and Asian immigrants responded to discriminatory practices by investing in human capital, enhancing English proficiency, and adopting Americanized names. Furthermore, the triple-difference estimates reveal that these effects are more pronounced in regions characterized by heightened discrimination against Asians.},
  keywords = {Chinese Exclusion Act,Discrimination,Immigrant assimilation},
  file = {zotero://open-pdf/library/items/5LJH8LTM?5bd91e344200ed803ee01ad3e677b225.pdf;/Users/dante/Zotero/storage/MHVWDGZ5/S001449832400041X.html;zotero://open-pdf/library/items/TL6V8RGP?Chen and Xie - 2024 - Institutional discrimination and assimilation Evidence from the Chinese Exclusion Act of 1882.pdf}
}

@article{chettyEffectsExposureBetter2016,
