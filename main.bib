@article{chatterjeeInsuringStudentLoans2012,
  title = {Insuring Student Loans against the Financial Risk of Failing to Complete College},
  author = {Chatterjee, Satyajit and Ionescu, Felicia},
  year = {2012},
  journal = {Quantitative Economics},
  volume = {3},
  number = {3},
  pages = {393--420},
  issn = {1759-7331},
  doi = {10.3982/QE100},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.3982/QE100},
  urldate = {2024-10-15},
  abstract = {Participants in student loan programs must repay loans in full regardless of whether they complete college. But many students who take out a loan do not earn a degree (the dropout rate among college students is between 33 and 50 percent). We examine whether insurance, in the form of loan forgiveness in the event of failure to complete college, can be offered, taking into account moral hazard and adverse selection. To do so, we develop a model that accounts for college enrollment and graduation rates among recent U.S. high school graduates. In our model, students may fail to earn a degree because they either fail college or choose to leave voluntarily. We find that if loan forgiveness is offered only when a student fails college, average welfare increases by 2.40 percent (in consumption equivalent units) without much effect on either enrollment or graduation rates. If loan forgiveness is offered against both failure and voluntary departure, welfare increases by 2.15 percent, and both enrollment and graduation are higher.},
  copyright = {Copyright {\copyright} 2012 Satyajit Chatterjee and Felicia Ionescu},
  langid = {english},
  keywords = {government student loans,optimal insurance},
  file = {zotero://open-pdf/library/items/EIHE6APD?Chatterjee and Ionescu - 2012 - Insuring student loans against the financial risk of failing to complete college.pdf;/Users/dante/Zotero/storage/RK7VSVXN/QE100.html}
}

@article{chenImpactSkillBasedImmigration2015,
