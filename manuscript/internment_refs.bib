}

@article{danzerEthnicEnclavesImpede2013,
  title = {Do {{Ethnic Enclaves Impede Immigrants}}' {{Integration}}? {{Evidence}} from a {{Quasi-experimental Social-interaction Approach}}},
  shorttitle = {Do {{Ethnic Enclaves Impede Immigrants}}' {{Integration}}?},
  author = {Danzer, Alexander M. and Yaman, Firat},
  year = 2013,
  journal = {Review of International Economics},
  volume = {21},
  number = {2},
  pages = {311--325},
  issn = {1467-9396},
  doi = {10.1111/roie.12038},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/roie.12038},
  urldate = {2022-12-09},
  abstract = {It is widely debated whether immigrants who live among co-ethnics are less willing to integrate into the host society. Exploiting the quasi-experimental guest worker placement across German regions during the 1960/70s as well as information on immigrants' inter-ethnic contact networks and social activities, we are able to identify the causal effect of ethnic concentration on social integration. The exogenous placement of immigrants `switches off' observable and unobservable differences in the willingness or ability to integrate which have confounded previous studies. Evidence suggests that the presence of co-ethnics increases migrants' interaction cost with natives and thus reduces the likelihood of integration.},
  langid = {english},
  file = {zotero://open-pdf/library/items/3VEX5832?Danzer and Yaman - 2013 - Do Ethnic Enclaves Impede Immigrants' Integration.pdf;/Users/dante/Zotero/storage/MYBSERGN/roie.html}
}

@misc{davisRacialEthnicDifferences2018,
  type = {{{SSRN Scholarly Paper}}},
  title = {Racial and {{Ethnic Differences}} in the {{Geography}} of {{Intergenerational Mobility}}},
  author = {Davis, Jonathan and Mazumder, Bhashkar},
  year = 2018,
  month = mar,
  number = {3138979},
  eprint = {3138979},
  publisher = {Social Science Research Network},
  address = {Rochester, NY},
  doi = {10.2139/ssrn.3138979},
  url = {https://papers.ssrn.com/abstract=3138979},
  urldate = {2024-11-22},
  abstract = {We use the NLSY79 to produce the first estimates of intergenerational mobility in the U.S. by both region and race/ethnicity. We show that gaps in intergenerational mobility by race are significantly larger than those by region. In particular, there is no region in the United States where it is better to be poor and black compared to being equally poor and white. We also show that the expected rank of Hispanics falls between that of whites and blacks. We find that the low mobility in the Southeast of the US documented by Chetty et al (2014) is actually driven by low mobility by whites and that blacks who grew up in the Southeast actually experience higher mobility than blacks growing up in the Northeast and Midwest. We also directly examine the role of migration and find that it plays little role in explaining the regional heterogeneity in intergenerational mobility. Finally, we use a rich set of individual covariates available in the NLSY --- including test scores --- and show that these can explain much of the gaps by race/ethnicity.},
  archiveprefix = {Social Science Research Network},
  langid = {english},
  keywords = {intergenerational mobility,racial differences},
  file = {zotero://open-pdf/library/items/HDADT3JD?Davis and Mazumder - 2018 - Racial and Ethnic Differences in the Geography of Intergenerational Mobility.pdf}
}

