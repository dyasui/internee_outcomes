@article{abramitzkyLeavingEnclaveHistorical2024,
  title = {Leaving the {{Enclave}}: {{Historical Evidence}} on {{Immigrant Mobility}} from the {{Industrial Removal Office}}},
  shorttitle = {Leaving the {{Enclave}}},
  author = {Abramitzky, Ran and Boustan, Leah and Connor, Dylan},
  year = 2024,
  journal = {Journal of Economic History},
  doi = {10.3386/w27372},
  url = {https://www.cambridge.org/core/journals/journal-of-economic-history/article/leaving-the-enclave-historical-evidence-on-immigrant-mobility-from-the-industrial-removal-office/820BFB74CA7F64E4159E91A37055F645},
  abstract = {We study a program that funded 39,000 Jewish households in New York City to leave enclave neighborhoods circa 1910. Compared to their neighbors with the same occupation and income score at baseline, program participants earned 4 percent more ten years after removal, and these gains persisted to the next generation. Men who left enclaves also married spouses with less Jewish names, but they did not choose less Jewish names for their children. Gains were largest for men who spent more years outside of an enclave. Our results suggest that leaving ethnic neighborhoods could facilitate economic advancement and assimilation into the broader society, but might make it more difficult to retain cultural identity.},
  keywords = {19th century,20th century,Age of Migration,assimilation,economic history,economic mobility,enumeration districts,ethnic enclaves,geolocation,Industrial Removal Office (IRO),Jewish Americans,linked data,migration,New York City,OCCSCORE},
  file = {zotero://open-pdf/library/items/VURK9PKL?iro\_june8\_nber.pdf}
}

